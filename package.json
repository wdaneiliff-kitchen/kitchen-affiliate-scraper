{
  "name": "kitchen-scripts",
  "private": true,
  "description": "Affiliate commission scrapers monorepo",
  "scripts": {
    "bixgrow": "pnpm --filter @kitchen/bixgrow start",
    "bixgrow:scrape": "pnpm --filter @kitchen/bixgrow scrape",
    "socialsnowball": "pnpm --filter @kitchen/socialsnowball start",
    "socialsnowball:scrape": "pnpm --filter @kitchen/socialsnowball scrape",
    "socialsnowball:all": "pnpm --filter @kitchen/socialsnowball start -- --account=all",
    "socialsnowball:all:scrape": "pnpm --filter @kitchen/socialsnowball scrape -- --account=all",
    "uppromote": "pnpm --filter @kitchen/uppromote start",
    "uppromote:scrape": "pnpm --filter @kitchen/uppromote scrape",
    "uppromote:all": "pnpm --filter @kitchen/uppromote start -- --account=all",
    "uppromote:all:scrape": "pnpm --filter @kitchen/uppromote scrape -- --account=all",
    "shortly": "pnpm --filter @kitchen/shortly start",
    "affiliatly": "pnpm --filter @kitchen/affiliatly start",
    "affiliatly:scrape": "pnpm --filter @kitchen/affiliatly scrape",
    "goaffpro": "pnpm --filter @kitchen/goaffpro start",
    "goaffpro:scrape": "pnpm --filter @kitchen/goaffpro scrape",
    "rpm": "pnpm --filter @kitchen/rpm start",
    "rpm:scrape": "pnpm --filter @kitchen/rpm scrape",
    "refersion": "pnpm --filter @kitchen/refersion start",
    "refersion:scrape": "pnpm --filter @kitchen/refersion scrape",
    "scraper": "gh workflow run scrape-and-upload.yml --repo wdaneiliff-kitchen/kitchen-affiliate-scraper"
  },
  "packageManager": "pnpm@9.14.2"
}

